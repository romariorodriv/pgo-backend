NODE_ENV=development
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"
SHADOW_DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE_SHADOW?schema=public"
JWT_SECRET="replace-with-at-least-32-random-characters"
JWT_EXPIRES_IN=15m
PORT=3000
GOOGLE_CLIENT_ID="your-android-or-web-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_IDS="android-client-id.apps.googleusercontent.com,ios-client-id.apps.googleusercontent.com"
CORS_ORIGINS="https://pgoapp.com,https://www.pgoapp.com"
