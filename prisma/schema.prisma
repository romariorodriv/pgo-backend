// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum MatchType {
  FRIENDLY
  RANKED
  TOURNAMENT
}

enum MatchStatus {
  DRAFT
  COMPLETED
  CANCELED
}

enum ExperienceLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  PRO
}

enum TournamentStatus {
  DRAFT
  PUBLISHED
  COMPLETED
  CANCELED
}

enum TournamentRegistrationMode {
  SOLO
  WITH_PARTNER
}

enum TournamentRegistrationStatus {
  PENDING
  CONFIRMED
  CANCELED
}

enum TournamentMatchStatus {
  PENDING
  LIVE
  FINISHED
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  REJECTED
  BLOCKED
}

enum OpenMatchAlertStatus {
  OPEN
  FULL
  COMPLETED
  CANCELED
}

enum OpenMatchCoordinationStatus {
  ARRIVED
  ON_THE_WAY
  ARRIVING_10
  CANNOT_GO
}

enum OpenMatchInvitationStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELED
}

model User {
  id                               String                        @id @default(uuid())
  name                             String
  email                            String                        @unique
  googleId                         String?                       @unique @map("google_id")
  passwordHash                     String                        @map("password_hash")
  isActive                         Boolean                       @default(true) @map("is_active")
  allowMatchInvites                Boolean                       @default(true) @map("allow_match_invites")
  createdAt                        DateTime                      @default(now()) @map("created_at")
  updatedAt                        DateTime                      @updatedAt @map("updated_at")
  profile                          Profile?
  createdMatches                   Match[]
  createdTournaments               Tournament[]
  matchParticipations              MatchParticipant[]
  tournamentRegistrations          TournamentRegistration[]      @relation("TournamentRegistrant")
  partneredTournamentRegistrations TournamentRegistration[]      @relation("TournamentPartner")
  sentFriendships                  Friendship[]                  @relation("FriendshipRequester")
  receivedFriendships              Friendship[]                  @relation("FriendshipAddressee")
  userAFriendships                 Friendship[]                  @relation("FriendshipUserA")
  userBFriendships                 Friendship[]                  @relation("FriendshipUserB")
  pushDeviceTokens                 PushDeviceToken[]
  notifications                    AppNotification[]
  supportReports                   SupportReport[]
  organizedOpenMatchAlerts         OpenMatchAlert[]              @relation("OpenMatchOrganizer")
  openMatchJoins                   OpenMatchParticipant[]
  openMatchInvitations             OpenMatchInvitation[]         @relation("OpenMatchInvitee")
  openMatchCoordinationUpdates     OpenMatchCoordinationUpdate[]

  @@map("users")
}

model PushDeviceToken {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  token      String   @unique
  platform   String
  lastSeenAt DateTime @default(now()) @map("last_seen_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_device_tokens")
}

model AppNotification {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  type      String
  title     String
  body      String
  data      Json?
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, readAt])
  @@map("app_notifications")
}

model SupportReport {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  type            String
  subject         String
  description     String
  screenshotLabel String?  @map("screenshot_label")
  createdAt       DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("support_reports")
}

model Profile {
  id                            String           @id @default(uuid())
  userId                        String           @unique @map("user_id")
  user                          User             @relation(fields: [userId], references: [id])
  photoUrl                      String?          @map("photo_url")
  experiencePoints              Int              @default(0) @map("experience_points")
  category                      String?
  categorySuggested             String?          @map("category_suggested")
  categoryPreliminary           String?          @map("category_preliminary")
  categoryMaxApplied            String?          @map("category_max_applied")
  categoryScore                 Int?             @map("category_score")
  categoryQuizAnswers           Json?            @map("category_quiz_answers")
  categoryIsProvisional         Boolean          @default(false) @map("category_is_provisional")
  categoryOrigin                String?          @map("category_origin")
  preferredClub                 String?          @map("preferred_club")
  preferredSide                 String?          @map("preferred_side")
  racketModel                   String?          @map("racket_model")
  experienceLevel               ExperienceLevel? @map("experience_level")
  rankingPosition               Int              @default(0) @map("ranking_position")
  wins                          Int              @default(0)
  weeklyStreak                  Int              @default(0) @map("weekly_streak")
  friendsCount                  Int              @default(0) @map("friends_count")
  followersCount                Int              @default(0) @map("followers_count")
  followingCount                Int              @default(0) @map("following_count")
  socialNotificationsCount      Int              @default(0) @map("social_notifications_count")
  hasSeenHomeGuide              Boolean          @default(false) @map("has_seen_home_guide")
  hasCompletedInitialOnboarding Boolean          @default(false) @map("has_completed_initial_onboarding")
  createdAt                     DateTime         @default(now()) @map("created_at")
  updatedAt                     DateTime         @updatedAt @map("updated_at")

  @@map("profiles")
}

model Friendship {
  id          String           @id @default(uuid())
  requesterId String           @map("requester_id")
  addresseeId String           @map("addressee_id")
  userAId     String           @map("user_a_id")
  userBId     String           @map("user_b_id")
  status      FriendshipStatus @default(PENDING)
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  requester User @relation("FriendshipRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee User @relation("FriendshipAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)
  userA     User @relation("FriendshipUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB     User @relation("FriendshipUserB", fields: [userBId], references: [id], onDelete: Cascade)

  @@unique([userAId, userBId])
  @@index([requesterId, status])
  @@index([addresseeId, status])
  @@index([userAId])
  @@index([userBId])
  @@map("friendships")
}

model Match {
  id              String             @id @default(uuid())
  createdById     String
  createdBy       User               @relation(fields: [createdById], references: [id])
  clubName        String
  playedAt        DateTime
  matchType       MatchType
  status          MatchStatus
  photoUrl        String?            @map("photo_url")
  description     String?
  winnerTeam      Int?               @map("winner_team")
  games           Json?
  xpAwardedAt     DateTime?          @map("xp_awarded_at")
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  participants    MatchParticipant[]
  openMatchResult OpenMatchAlert?    @relation("OpenMatchResult")

  @@map("matches")
}

model MatchParticipant {
  id        String   @id @default(uuid())
  matchId   String   @map("match_id")
  userId    String   @map("user_id")
  slot      Int
  team      Int
  createdAt DateTime @default(now()) @map("created_at")
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([matchId, slot])
  @@unique([matchId, userId])
  @@map("match_participants")
}

model OpenMatchAlert {
  id                  String                        @id @default(uuid())
  organizerId         String                        @map("organizer_id")
  organizer           User                          @relation("OpenMatchOrganizer", fields: [organizerId], references: [id], onDelete: Cascade)
  category            String
  format              String
  startsAt            DateTime                      @map("starts_at")
  club                String
  district            String
  courtStatus         String                        @map("court_status")
  missingPlayers      Int                           @map("missing_players")
  costPerPerson       Int                           @map("cost_per_person")
  paymentLabel        String                        @map("payment_label")
  comment             String?
  status              OpenMatchAlertStatus          @default(OPEN)
  resultMatchId       String?                       @unique @map("result_match_id")
  completedAt         DateTime?                     @map("completed_at")
  createdAt           DateTime                      @default(now()) @map("created_at")
  updatedAt           DateTime                      @updatedAt @map("updated_at")
  resultMatch         Match?                        @relation("OpenMatchResult", fields: [resultMatchId], references: [id], onDelete: SetNull)
  participants        OpenMatchParticipant[]
  invitations         OpenMatchInvitation[]
  coordinationUpdates OpenMatchCoordinationUpdate[]

  @@index([status, startsAt])
  @@index([organizerId])
  @@map("open_match_alerts")
}

model OpenMatchCoordinationUpdate {
  id        String                      @id @default(uuid())
  alertId   String                      @map("alert_id")
  userId    String                      @map("user_id")
  status    OpenMatchCoordinationStatus
  message   String
  createdAt DateTime                    @default(now()) @map("created_at")
  alert     OpenMatchAlert              @relation(fields: [alertId], references: [id], onDelete: Cascade)
  user      User                        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([alertId, createdAt])
  @@index([userId])
  @@map("open_match_coordination_updates")
}

model OpenMatchInvitation {
  id          String                    @id @default(uuid())
  alertId     String                    @map("alert_id")
  inviteeId   String                    @map("invitee_id")
  status      OpenMatchInvitationStatus @default(PENDING)
  respondedAt DateTime?                 @map("responded_at")
  createdAt   DateTime                  @default(now()) @map("created_at")
  updatedAt   DateTime                  @updatedAt @map("updated_at")
  alert       OpenMatchAlert            @relation(fields: [alertId], references: [id], onDelete: Cascade)
  invitee     User                      @relation("OpenMatchInvitee", fields: [inviteeId], references: [id], onDelete: Cascade)

  @@unique([alertId, inviteeId])
  @@index([inviteeId, status])
  @@index([alertId, status])
  @@map("open_match_invitations")
}

model OpenMatchParticipant {
  id        String         @id @default(uuid())
  alertId   String         @map("alert_id")
  userId    String         @map("user_id")
  createdAt DateTime       @default(now()) @map("created_at")
  alert     OpenMatchAlert @relation(fields: [alertId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([alertId, userId])
  @@index([userId])
  @@map("open_match_participants")
}

model Tournament {
  id                String                   @id @default(uuid())
  createdById       String                   @map("created_by_id")
  createdBy         User                     @relation(fields: [createdById], references: [id])
  title             String
  slug              String?                  @unique
  tournamentType    String                   @map("tournament_type")
  pairingMode       String                   @default("FIXED") @map("pairing_mode")
  playerCapacity    Int                      @map("player_capacity")
  modality          String
  format            String
  location          String
  address           String?
  city              String
  district          String
  startsAt          DateTime                 @map("starts_at")
  prize             String
  entryFee          Int                      @map("entry_fee")
  category          String
  status            TournamentStatus         @default(PUBLISHED)
  registrationsOpen Boolean                  @default(true) @map("registrations_open")
  photoUrl          String?                  @map("photo_url")
  description       String?
  createdAt         DateTime                 @default(now()) @map("created_at")
  updatedAt         DateTime                 @updatedAt @map("updated_at")
  registrations     TournamentRegistration[]
  matches           TournamentMatch[]

  @@map("tournaments")
}

model TournamentRegistration {
  id            String                       @id @default(uuid())
  tournamentId  String                       @map("tournament_id")
  userId        String                       @map("user_id")
  partnerUserId String?                      @map("partner_user_id")
  mode          TournamentRegistrationMode
  status        TournamentRegistrationStatus @default(PENDING)
  preferredSide String?                      @map("preferred_side")
  availability  String?
  createdAt     DateTime                     @default(now()) @map("created_at")
  updatedAt     DateTime                     @updatedAt @map("updated_at")
  tournament    Tournament                   @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user          User                         @relation("TournamentRegistrant", fields: [userId], references: [id], onDelete: Restrict)
  partnerUser   User?                        @relation("TournamentPartner", fields: [partnerUserId], references: [id], onDelete: Restrict)

  @@unique([tournamentId, userId])
  @@unique([tournamentId, partnerUserId])
  @@map("tournament_registrations")
}

model TournamentMatch {
  id           String                @id @default(uuid())
  tournamentId String                @map("tournament_id")
  stage        String
  matchNumber  Int                   @map("match_number")
  courtLabel   String                @map("court_label")
  scheduledAt  DateTime              @map("scheduled_at")
  startedAt    DateTime?             @map("started_at")
  teamOneLabel String                @map("team_one_label")
  teamTwoLabel String                @map("team_two_label")
  winnerLabel  String?               @map("winner_label")
  status       TournamentMatchStatus @default(PENDING)
  score        String?
  createdAt    DateTime              @default(now()) @map("created_at")
  updatedAt    DateTime              @updatedAt @map("updated_at")
  tournament   Tournament            @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, stage, matchNumber])
  @@map("tournament_matches")
}
